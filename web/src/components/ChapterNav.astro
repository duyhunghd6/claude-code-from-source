---
import type { ChapterConfig } from '../book.config';

interface Props {
  prev: ChapterConfig | null;
  next: ChapterConfig | null;
  lang?: string;
}

const { prev, next, lang = 'vi' } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const localeBase = lang === 'en' ? `${base}en/` : base;
---

<nav class="flex justify-between items-stretch gap-4 mt-16 pt-8 border-t border-[var(--color-border)] dark:border-[#333]">
  {prev ? (
    <a
      href={`${localeBase}${prev.slug}/`}
      class="group flex-1 flex flex-col p-4 rounded-lg border border-[var(--color-border)] dark:border-[#333] hover:border-[var(--color-terracotta)] transition-colors"
    >
      <span class="text-xs text-[var(--color-muted)] mb-1 flex items-center gap-1">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        {lang === 'vi' ? 'Trang trước' : 'Previous'}
      </span>
      <span class="text-sm font-medium text-[var(--color-charcoal)] dark:text-[var(--color-cream)] group-hover:text-[var(--color-terracotta)] transition-colors">
        Ch {prev.number}. {prev.title}
      </span>
    </a>
  ) : <div class="flex-1" />}

  {next ? (
    <a
      href={`${localeBase}${next.slug}/`}
      class="group flex-1 flex flex-col items-end text-right p-4 rounded-lg border border-[var(--color-border)] dark:border-[#333] hover:border-[var(--color-terracotta)] transition-colors"
    >
      <span class="text-xs text-[var(--color-muted)] mb-1 flex items-center gap-1">
        {lang === 'vi' ? 'Trang kế' : 'Next'}
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </span>
      <span class="text-sm font-medium text-[var(--color-charcoal)] dark:text-[var(--color-cream)] group-hover:text-[var(--color-terracotta)] transition-colors">
        Ch {next.number}. {next.title}
      </span>
    </a>
  ) : <div class="flex-1" />}
</nav>
